{
  "expo": {
    "name": "StatuteIQ",
    "slug": "statuteiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "statuteiq",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#1B3A6B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vorotech.statuteiq"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B3A6B"
      },
      "package": "com.vorotech.statuteiq"
    },
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec792e05-0abc-406c-8432-4bc8225c6cbc"
      }
    },
    "owner": "iclawdius",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ec792e05-0abc-406c-8432-4bc8225c6cbc"
    }
  }
}
